{
  "expo": {
    "name": "Ciclo de Inventario",
    "slug": "estoqueaudit",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "estoqueaudit",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.ruffghanor20.estoqueaudit",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Escanear codigos de barras e ler textos de etiquetas do estoque.",
        "NSPhotoLibraryUsageDescription": "Salvar relatorios exportados.",
        "NSPhotoLibraryAddUsageDescription": "Salvar relatorios de contagem."
      }
    },
    "android": {
      "package": "com.ruffghanor20.estoqueaudit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#09090B"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Escanear codigos de barras e capturar textos de etiquetas para identificar itens do estoque."
        }
      ],
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090B"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-sharing",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc3d6bab-22a7-4816-8dfd-b4387f727b53"
      }
    },
    "owner": "ruffghanor20"
  }
}
