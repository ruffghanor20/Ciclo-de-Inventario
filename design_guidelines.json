{
  "meta": {
    "app_name": "EstoqueAudit",
    "version": "1.0.0",
    "platform": "React Native (Expo SDK 54)",
    "theme_mode": "dark",
    "persona": "The Performance Pro (Industrial/Tactical)"
  },
  "brand_identity": {
    "core_concept": "Tactical Minimalism",
    "emotional_tone": "Precision, reliability, industrial strength",
    "visual_motif": "High-contrast data, obsidian surfaces, electric indicators"
  },
  "colors": {
    "palette": {
      "background": {
        "primary": "#09090B",
        "secondary": "#18181B",
        "tertiary": "#27272A",
        "modal_overlay": "rgba(0, 0, 0, 0.85)"
      },
      "text": {
        "primary": "#FAFAFA",
        "secondary": "#A1A1AA",
        "tertiary": "#52525B",
        "inverse": "#09090B"
      },
      "brand": {
        "primary": "#3B82F6",
        "primary_active": "#2563EB",
        "accent": "#F59E0B",
        "divergence": "#EF4444",
        "success": "#10B981"
      },
      "border": {
        "subtle": "#27272A",
        "strong": "#3F3F46",
        "active": "#3B82F6"
      }
    },
    "functional_mapping": {
      "background_main": "#09090B",
      "card_surface": "#18181B",
      "text_main": "#FAFAFA",
      "text_muted": "#A1A1AA",
      "primary_action": "#3B82F6",
      "error_state": "#EF4444",
      "success_state": "#10B981",
      "warning_state": "#F59E0B",
      "divider": "#27272A"
    }
  },
  "typography": {
    "font_family": {
      "main": "System",
      "data": "System (Monospaced Variant recommended if available, else System)"
    },
    "scale": {
      "display": { "size": 32, "line_height": 38, "weight": "700", "tracking": -0.5 },
      "h1": { "size": 24, "line_height": 32, "weight": "700", "tracking": -0.25 },
      "h2": { "size": 20, "line_height": 28, "weight": "600", "tracking": 0 },
      "h3": { "size": 18, "line_height": 24, "weight": "600", "tracking": 0 },
      "body_lg": { "size": 16, "line_height": 24, "weight": "400", "tracking": 0 },
      "body_md": { "size": 14, "line_height": 20, "weight": "400", "tracking": 0 },
      "caption": { "size": 12, "line_height": 16, "weight": "500", "tracking": 0.5 },
      "tiny": { "size": 10, "line_height": 12, "weight": "700", "tracking": 1.0 }
    }
  },
  "spacing": {
    "units": {
      "xs": 4,
      "sm": 8,
      "md": 12,
      "lg": 16,
      "xl": 24,
      "2xl": 32,
      "3xl": 48
    },
    "layout": {
      "screen_padding": 16,
      "card_padding": 16,
      "section_gap": 24,
      "item_gap": 12
    },
    "touch_targets": {
      "min_height": 56,
      "icon_hit_slop": 12
    }
  },
  "components": {
    "buttons": {
      "primary": {
        "bg": "#3B82F6",
        "text": "#FAFAFA",
        "radius": 8,
        "height": 56,
        "font_weight": "600"
      },
      "secondary": {
        "bg": "#27272A",
        "text": "#FAFAFA",
        "radius": 8,
        "height": 56,
        "font_weight": "500"
      },
      "outline": {
        "bg": "transparent",
        "border": "#3F3F46",
        "text": "#A1A1AA",
        "radius": 8,
        "height": 56
      }
    },
    "cards": {
      "dashboard_stat": {
        "bg": "#18181B",
        "border": "#27272A",
        "radius": 12,
        "padding": 16
      },
      "list_item": {
        "bg": "#18181B",
        "border_bottom": "#27272A",
        "height": 72,
        "padding_h": 16
      }
    },
    "inputs": {
      "default": {
        "bg": "#09090B",
        "border": "#27272A",
        "radius": 8,
        "height": 56,
        "text_color": "#FAFAFA",
        "placeholder_color": "#52525B"
      },
      "focused": {
        "border": "#3B82F6",
        "bg": "#09090B"
      }
    }
  },
  "assets": {
    "icons": {
      "library": "lucide-react-native",
      "style": "stroke-width: 2",
      "size": {
        "sm": 16,
        "md": 24,
        "lg": 32
      }
    },
    "images": {
      "backgrounds": [
        {
          "url": "https://images.unsplash.com/photo-1622030411594-c282a63aa1bc?auto=format&fit=crop&q=80",
          "category": "auth_background",
          "description": "Minimal white metal warehouse frame, good for overlaying login forms with dark scrim"
        },
        {
          "url": "https://images.unsplash.com/photo-1694885156873-6a0823e14848?auto=format&fit=crop&q=80",
          "category": "empty_state_inventory",
          "description": "Long row of warehouse shelves"
        },
        {
          "url": "https://images.pexels.com/photos/4487363/pexels-photo-4487363.jpeg?auto=compress&cs=tinysrgb&w=800",
          "category": "splash_screen",
          "description": "Bright modern warehouse"
        }
      ]
    }
  },
  "react_native_implementation": {
    "styling_engine": "StyleSheet.create",
    "safe_area": "Use react-native-safe-area-context",
    "navigation": "expo-router or react-navigation (Tab based)",
    "lists": "Use FlatList or FlashList for inventory items (performance critical)",
    "storage": "expo-sqlite",
    "charts": "react-native-gifted-charts or victory-native",
    "rules": [
      "No inline styles for complex components.",
      "Use 'gap' property for layout spacing where supported, else margins.",
      "All touchables must have min-height 56px for gloved usage.",
      "Text inputs must have 'keyboardType' configured correctly (numeric for counts).",
      "Offline indicators must be visible in the header."
    ]
  },
  "accessibility": {
    "contrast": "WCAG AA Compliant (Text on Background > 4.5:1)",
    "touch_targets": "Minimum 48x48dp",
    "scaling": "Respect user font scale settings (allow FontScaling: true)"
  },
  "universal_guidelines": {
    "testing": "All interactive elements must include 'testID' prop.",
    "error_handling": "Use Toast (sonner-native or similar) for non-blocking errors.",
    "loading_states": "Use Skeleton loaders (gray-800 pulsing) instead of spinners for initial loads."
  }
}